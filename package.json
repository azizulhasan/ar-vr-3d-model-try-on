    "alertifyjs": "^1.14.0",
    "classnames": "^2.5.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.28.1",
    "react-scripts": "^5.0.1",
    "react-toastify": "^11.0.2"
  },
  "browser": {
    "child_process": false
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "gulp": "^5.0.0",
    "gulp-autoprefixer": "^7.0.1",
    "gulp-babel": "^8.0.0",
    "gulp-beautify": "^3.0.0",
    "gulp-checktextdomain": "^2.3.0",
    "gulp-clean-css": "^4.3.0",
    "gulp-concat": "^2.6.1",
    "gulp-copy": "^5.0.0",
    "gulp-env": "^0.4.0",
    "gulp-eslint": "^6.0.0",
    "gulp-js-prettify": "^0.1.0",
