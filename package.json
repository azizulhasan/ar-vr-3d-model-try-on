{
  "name": "ar-try-on",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "gulp test",
    "start": "react-scripts start",
    "eject": "react-scripts eject",
    "serve": "live-server",
    "watch": "cross-env NODE_ENV=development webpack --watch --progress --config=node_modules/laravel-mix/setup/webpack.config.js",
    "dev": "cross-env NODE_ENV=development webpack  --progress --hide-modules --config=node_modules/laravel-mix/setup/webpack.config.js",
    "hmr": "cross-env NODE_ENV=development webpack-dev-server --inline --hot --config=node_modules/laravel-mix/setup/webpack.config.js",
    "production": "cross-env NODE_ENV=production webpack --progress --config=node_modules/laravel-mix/setup/webpack.config.js",
    "block:build": "wp-scripts build ar-blocks/blocks.js --output-path=admin/js/ar-blocks",
    "block:start": "wp-scripts start ar-blocks/blocks.js --output-path=admin/js/ar-blocks --watch",
    "block2:build": "wp-scripts build ar-blocks/ar-try-on --output-path=admin/js/ar-blocks/ar-try-on",
    "block2:start": "wp-scripts start ar-blocks/ar-try-on/index.js --output-path=admin/js/ar-blocks/ar-try-on --watch",
    "makeZip": "gulp makeZip",
    "release": "gulp release",
    "copy": "gulp copy",
    "copyProButton": "gulp copyProButton",
    "tailwind": "npx tailwindcss -i src/tailwind.css -o public/css/ar-try-on.css --watch",
    "build": "concurrently \"npm run production\" \"npm run tailwind\" \"npm run compile\" \"gulp copyPro\""
  },
  "keywords": [
    "ar",
    "vr",
    "3d-model",
    "try-on"
  ],
  "author": "Azizul Hasan <azizulhasan.cr@gmail.com>",
  "license": "ISC",
